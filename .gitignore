# ---------------------------------------------------------------------------
# .gitignore — plain HTML / CSS / JavaScript static site
# ---------------------------------------------------------------------------

# OS files
.DS_Store
Thumbs.db

# Editor / tooling
.vscode/
.idea/
*.swp

# Local assistant settings & memory (machine-local, not part of the site)
.claude/settings.local.json
.remember/

# Dependencies & build output (if any get added later)
node_modules/
dist/
.cache/

# Environment / secrets
.env
.env.*

# Logs
*.log

# Local working/scratch directories
downloads/
tmp/
